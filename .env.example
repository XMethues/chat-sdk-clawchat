# ClawChat adapter configuration
CLAWCHAT_TOKEN=
CLAWCHAT_USER_ID=
CLAWCHAT_DEVICE_ID=
CLAWCHAT_BOT_USERNAME=clawchat-bot
CLAWCHAT_BASE_URL=https://app.clawling.com
